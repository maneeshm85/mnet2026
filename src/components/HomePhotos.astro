---
import { getCollection } from 'astro:content';

const photos = await getCollection('photos');
const sorted = photos.sort((a, b) => {
  const dateA = a.data.date ? a.data.date.valueOf() : 0;
  const dateB = b.data.date ? b.data.date.valueOf() : 0;
  return dateB - dateA;
});
---

<section class="home-section">
  <h2>Photos</h2>
  <div class="photo-grid">
    {sorted.map(set => (
      <a href={`/photos/${set.id}`} class="photo-card">
        <div class="photo-thumb">
          {set.data.banner
            ? <img src={`/photos-content/${set.id}/${set.data.banner}`} alt={set.data.title} />
            : <div class="no-image" />
          }
        </div>
        <div class="photo-meta">
          <span class="photo-title">{set.data.title}</span>
          {set.data.display_date && <span class="photo-date">{set.data.display_date}</span>}
        </div>
      </a>
    ))}
  </div>
  <a href="/photos" class="see-all">All photo sets →</a>
</section>

<style>
  .home-section {
    max-width: var(--max-w-wide);
    margin-bottom: 3rem;
  }

  h2 {
    font-size: 0.8rem;
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .photo-card {
    text-decoration: none;
    color: var(--fg);
  }

  .photo-thumb {
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--border);
    margin-bottom: 0.75rem;
  }

  .photo-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s;
  }

  .photo-card:hover img {
    opacity: 0.85;
  }

  .no-image {
    width: 100%;
    height: 100%;
    background: var(--border);
  }

  .photo-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }

  .photo-title {
    font-family: 'Lora', serif;
    font-size: 0.95rem;
  }

  .photo-date {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: var(--fg-muted);
    white-space: nowrap;
  }

  .see-all {
    display: inline-block;
    margin-top: 1.25rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: var(--fg-muted);
    text-decoration: none;
  }

  .see-all:hover { color: var(--fg); }
</style>