---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const photos = await getCollection('photos');
const sorted = photos.sort((a, b) => {
  const dateA = a.data.date ? a.data.date.valueOf() : 0;
  const dateB = b.data.date ? b.data.date.valueOf() : 0;
  return dateB - dateA;
});
---

<BaseLayout title="Photos — Maneesh Madambath">
  <div class="page-header">
    <h1>Photos</h1>
  </div>
  <div class="photo-grid">
    {sorted.map(set => (
      <a href={`/photos/${set.id}`} class="photo-card">
        <div class="photo-thumb">
          {set.data.banner
            ? <img src={`/photos-content/${set.id}/${set.data.banner}`} alt={set.data.title} />
            : <div class="no-image"></div>
          }
        </div>
        <div class="photo-meta">
          <span class="photo-title">{set.data.title}</span>
          {set.data.display_date ? <span class="photo-date">{set.data.display_date}</span> : null}
        </div>
        {set.data.location ? <p class="photo-location">{set.data.location}</p> : null}
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    max-width: var(--max-w);
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2rem;
    letter-spacing: -0.02em;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .photo-card {
    text-decoration: none;
    color: var(--fg);
  }

  .photo-thumb {
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--border);
    margin-bottom: 0.75rem;
  }

  .photo-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s;
  }

  .photo-card:hover img { opacity: 0.85; }

  .no-image {
    width: 100%;
    height: 100%;
    background: var(--border);
  }

  .photo-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .photo-title {
    font-family: 'Lora', serif;
    font-size: 1rem;
  }

  .photo-date {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: var(--fg-muted);
    white-space: nowrap;
  }

  .photo-location {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: var(--fg-muted);
    margin: 0;
  }
</style>